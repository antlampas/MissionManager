class MissionService <<extern>>
class AssignmentService <<extern>>
class ActivityService <<extern>>
class BadgeService <<extern>>
class PersonService <<extern>>
class AclService <<extern>>
class AuthorizationPolicy <<extern>>
class OperatorIdentityProvider <<extern>>
class ExtensionRegistry <<extern>>

' ── Relazioni Web ────────────────────────────────────────────
create_web_blueprint --> ACLMiddleware
create_web_blueprint --> RealtimeNotifier
create_web_blueprint --> MissionRouteHandler
create_web_blueprint --> AssignmentRouteHandler
create_web_blueprint --> ObjectiveRouteHandler
create_web_blueprint --> ActivityRouteHandler
create_web_blueprint --> AclRouteHandler

ACLMiddleware --> OperatorIdentityProvider
ACLMiddleware --> AuthorizationPolicy

MissionRouteHandler --> MissionService
AssignmentRouteHandler --> AssignmentService
AssignmentRouteHandler --> RealtimeNotifier
AssignmentRouteHandler --> MissionService
AssignmentRouteHandler --> PersonService
AssignmentRouteHandler --> BadgeService
ObjectiveRouteHandler --> AssignmentService
