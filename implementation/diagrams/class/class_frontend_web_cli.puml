@startuml class_frontend_web_cli
' SPDX-License-Identifier: CC-BY-SA-4.0
title Layer 5 — Web App (Quart) e CLI (Click)

skinparam classAttributeIconSize 0
skinparam defaultTextAlignment left

skinparam class {
  BackgroundColor<<web>>     #E8F8F5
  BorderColor<<web>>         #1A9850

  BackgroundColor<<cli>>     #FEF9E7
  BorderColor<<cli>>         #D4AC0D

  BackgroundColor<<extern>>  #EEEEEE
  BorderColor<<extern>>      #AAAAAA
}

skinparam NoteBackgroundColor #FEF9E7
skinparam NoteBorderColor #F0B27A

' ══════════════════════════════════════════
' Web App (Quart)
' ══════════════════════════════════════════

class create_web_blueprint <<web factory>> {
  +create_web_blueprint(svcs, auth_policy, identity_provider, auth_service, ...) Blueprint
  .. registra sul blueprint ..
  route Web (lista/dettaglio + creazione) e /setup
  ACLMiddleware, RealtimeNotifier (/ws), /static
  error handler eccezioni di dominio -> JSON
}

class ACLMiddleware <<web>> {
  -_identity_provider: OperatorIdentityProvider
  -_auth_policy: AuthorizationPolicy
  -_endpoint_acl: dict[endpoint, (Operation, tipo, view-arg) | SERVICE_ENFORCED]
  +async check_acl() [before_request]
}

class RealtimeNotifier <<web>> {
  -_connected: set[Connection]
  +async connect(conn: Connection) void
  +async disconnect(conn: Connection) void
  +async broadcast(event: str, data: dict) void
  +async on_assignment_status_change(assignment_id: str, new_status: str) void
  +async on_activity_status_change(activity_id: str, new_status: str) void
}

class MissionRouteHandler <<web>> {
  -_mission_svc: MissionService
  +async list_missions() Response
  +async new_mission_form() Response
  +async create_mission() Response
  +async get_mission(id: str) Response
  +async delete_mission(id: str) Response
  .. solo blueprint (immutabile): nessuna ..
  .. assegnazione né aggiunta obiettivi ..
}

class AssignmentRouteHandler <<web>> {
  -_assignment_svc: AssignmentService
  -_notifier: RealtimeNotifier
  -_badge_svc: BadgeService
  -_person_svc: PersonService
  -_mission_svc: MissionService
  .. pagina dedicata alle assegnazioni ..
  +async list_assignments_page() Response
  +async new_assignment_form() Response
  +async create_assignment_global() Response
  .. dettaglio assignment ..
  +async get_assignment(id: str) Response
  +async assign_assignment(id: str) Response
  +async update_assignment_status(id: str) Response
  +async award_badge(id: str) Response
}

class ObjectiveRouteHandler <<web>> {
  -_assignment_svc: AssignmentService
  +async get_objective(id: str) Response
  +async list_activities(id: str) Response
}

class AclRouteHandler <<web>> {
  -_acl_svc: AclService
  -_person_svc: PersonService
  .. pagina /acl: profili + entry ..
  +async get_page() Response
  +async set_profile() Response
  +async remove_profile_group() Response
  +async create_entry() Response
  +async delete_entry(entry_id) Response
}

class ActivityRouteHandler <<web>> {
  -_activity_svc: ActivityService
  -_notifier: RealtimeNotifier
  +async get_activity(id: str) Response
  +async update_activity_status(id: str) Response
  +async assign_to_activity(id: str) Response
}

' ══════════════════════════════════════════
' CLI (Click)
' ══════════════════════════════════════════

class CLIApp <<cli>> {
  +cli() [Click group radice con @click.pass_context]
  +setup_services(ctx: Context) void
}

class OutputFormatter <<cli>> {
  {static} +mission_table(missions: list[MissionDTO]) str
  {static} +assignment_detail(dto: AssignmentDTO) str
  {static} +badge_award(dto: BadgeAwardDTO) str
  {static} +json_output(data: Any) str
  {static} +success(msg: str) void
  {static} +error(msg: str) void
}

class MissionCommands <<cli>> {
  +create() [click.command, @require_acl]
  +get() [click.command, @require_acl]
  +list() [click.command, @require_acl]
  +delete() [click.command, @require_acl]
}

class AssignmentCommands <<cli>> {
  +create() [click.command, @require_acl]
  +assign() [click.command, @require_acl]
  +get() [click.command, @require_acl]
  +list() [click.command, @require_acl]
  +set_status() [click.command, @require_acl]
  +badge() [click.command, @require_acl]
}

class ActivityCommands <<cli>> {
  +get() [click.command, @require_acl]
  +assign_to() [click.command, @require_acl]
  +unassign() [click.command, @require_acl]
  +set_status() [click.command, @require_acl]
}

class BadgeCommands <<cli>> {
  +create() [click.command, @require_acl]
  +get() [click.command, @require_acl]
  +list() [click.command, @require_acl]
  +list_by_person() [click.command, @require_acl]
}

class PersonCommands <<cli>> {
  +add() [click.command, @require_acl]
  +update() [click.command, @require_acl]
  +remove() [click.command, @require_acl]
  +get() [click.command, @require_acl]
  +list() [click.command, @require_acl]
  +list_by_group() [click.command, @require_acl]
  +group_add() [click.command, @require_acl]
  +group_remove() [click.command, @require_acl]
  +group_list() [click.command, @require_acl]
  +group_show() [click.command, @require_acl]
}

